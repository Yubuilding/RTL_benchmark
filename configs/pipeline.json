{
  "problem_glob": "benchmarks/**/*.json",
  "max_iterations": 3,
  "generation": {
    "temperature": 0.0,
    "max_tokens": 1024,
    "timeout_seconds": 60
  },
  "execution": {
    "mode": "local",
    "timeout_seconds": 20,
    "docker_binary": "docker",
    "docker_image": "rtl-benchmark-tools:latest",
    "docker_build_context": ".",
    "dockerfile": "Dockerfile",
    "container_workdir": "/workspace",
    "docker_network": "none",
    "docker_read_only_rootfs": true,
    "docker_tmpfs_mounts": [
      "/tmp"
    ],
    "docker_security_opts": [
      "no-new-privileges:true"
    ],
    "docker_cap_drop": [
      "ALL"
    ],
    "docker_pids_limit": 256,
    "docker_memory": "1g",
    "docker_cpus": "1.0"
  },
  "selection": {
    "include_any": [],
    "exclude_any": [],
    "providers": [],
    "max_models": 0
  },
  "run_root": "results/runs",
  "raw_results_dir": "results/raw",
  "leaderboard_path": "results/leaderboard.json",
  "state_path": ".state/known_models.json",
  "sources": [
    {
      "type": "file_feed",
      "path": "data/model_feeds/open_models.json"
    },
    {
      "type": "huggingface",
      "enabled": false,
      "limit": 50,
      "window_hours": 24,
      "query": "text-generation",
      "id_contains": [
        "rtl",
        "verilog",
        "systemverilog",
        "hdl"
      ]
    },
    {
      "type": "openrouter",
      "enabled": false,
      "models": [
        {
          "id": "openai/gpt-4.1-mini"
        }
      ]
    },
    {
      "type": "openai",
      "enabled": false,
      "provider": "openai",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "models": [
        {
          "id": "gpt-4.1-mini"
        },
        {
          "id": "o3-mini"
        }
      ]
    },
    {
      "type": "anthropic",
      "enabled": false,
      "provider": "anthropic",
      "base_url": "https://api.anthropic.com",
      "api_key_env": "ANTHROPIC_API_KEY",
      "version": "2023-06-01",
      "models": [
        {
          "id": "claude-3-5-sonnet-latest"
        }
      ]
    }
  ]
}
